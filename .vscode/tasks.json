{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "compile extension",
			"type": "shell",
			"command": "bun run build:vsx",
			"group": "build",
			"presentation": {
				"panel": "dedicated",
				"reveal": "never"
			},
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "watch extension",
			"type": "shell",
			"command": "cd packages/forge-fm-vsx && bun run watch",
			"isBackground": true,
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"panel": "dedicated",
				"reveal": "never"
			},
			"problemMatcher": [
				"$tsc-watch"
			]
		}
	]
}
