{
	"name": "@forge-fm/forge-graph",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Browser custom element and SVG renderer for Forge/Alloy instance graphs.",
	"exports": {
		".": {
			"import": "./dist/forge-graph.js",
			"types": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --entry-naming forge-graph.[ext] --target=browser --format=esm --sourcemap=linked",
		"watch": "bun build ./src/index.ts --outdir ./dist --entry-naming forge-graph.[ext] --target=browser --format=esm --sourcemap=linked --watch --no-clear-screen",
		"dev": "bun ./demo/index.html"
	},
	"dependencies": {
		"d3": "^7.9.0",
		"js-yaml": "^4.1.0",
		"perfect-arrows": "^0.3.7",
		"spytial-core": "github:sidprasad/cnd-core#451f650",
		"webcola": "^3.4.0"
	}
}
